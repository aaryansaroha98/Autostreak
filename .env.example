# Core
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=AutoStreak
APP_URL=http://localhost:3000

# Database (Neon/Railway Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autostreak?schema=public

# NextAuth v5
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
AUTH_TRUST_HOST=true

# GitHub OAuth App
GITHUB_ID=replace-with-github-oauth-client-id
GITHUB_SECRET=replace-with-github-oauth-client-secret

# Encryption key for PAT storage (32-byte base64)
ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Redis/BullMQ
REDIS_URL=redis://localhost:6379

# Optional internal cron protection
CRON_SECRET=replace-with-random-cron-secret
